# Copy to an untracked shell environment file on the TPU VM. Never commit
# credentials or Hugging Face tokens.
# Never infer JAX device count from the v4-64 marketing/core label. Replace
# every TODO with the values measured on the granted slice.
EXPECTED_TPU_DEVICES=TODO_GLOBAL_DEVICE_COUNT
# Set from the granted topology. Every TPU VM runs one JAX process.
EXPECTED_TPU_PROCESSES=TODO_HOST_COUNT
# Optional exact per-process gate; otherwise preflight derives it from global metadata.
EXPECTED_LOCAL_TPU_DEVICES=TODO_LOCAL_DEVICE_COUNT
SUNFISH_GCS_WORKDIR=gs://YOUR_BUCKET/sunfish/YOUR_RUN_PREFIX
SUNFISH_READINESS=gs://YOUR_BUCKET/sunfish/readiness
SUNFISH_SEED=gs://YOUR_BUCKET/sunfish/checkpoints/sunfish-stage05-first32-exact-tree
SUNFISH_SEED_MANIFEST=gs://YOUR_BUCKET/sunfish/checkpoints/sunfish-stage05-first32-exact-tree.json
SUNFISH_SEED_MANIFEST_SHA256=TODO_REAL_SHA256
# The controller renderer/uploader publishes this directory atomically only
# after source-matched Stage-0 P1-P5 parity passes. Never point at a template.
SUNFISH_DEPLOY_CONFIG_DIR=/home/YOUR_USER/sunfish-deploy/YOUR_RUN_TAG
SUNFISH_RUN_ID=YYYYMMDDTHHMMSSZ-purpose
SUNFISH_CONFIG=/home/YOUR_USER/sunfish-deploy/YOUR_RUN_TAG/sunfish-smoke.toml
HF_HOME=/mnt/disks/sunfish-cache/huggingface
XLA_PYTHON_CLIENT_PREALLOCATE=false
